NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
APP_NAME=AthleteShield

# Runtime database URL. Use pooled URL for Supabase runtime if needed.
DATABASE_URL=postgresql://athleteshield:athleteshield@localhost:5432/athleteshield?schema=public

# Direct database URL for Prisma db push/migrations.
# For Supabase, use the direct/session connection, not the transaction pooler URL.
DIRECT_URL=postgresql://athleteshield:athleteshield@localhost:5432/athleteshield?schema=public

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-at-least-32-chars
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000

FILE_STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=uploads/encrypted

# Only required when FILE_STORAGE_DRIVER=s3.
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false

DOCUMENT_MASTER_KEY_BASE64=replace-with-32-byte-base64-key
ED25519_PRIVATE_KEY_PEM_BASE64=replace-with-base64-pem-private-key
ED25519_PUBLIC_KEY_PEM_BASE64=replace-with-base64-pem-public-key

AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=replace-with-internal-service-token

RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_DEFAULT=120
RATE_LIMIT_AUTH=10
RATE_LIMIT_REPORTS=8
RATE_LIMIT_VERIFICATION=60

LOG_LEVEL=info

SEED_ADMIN_EMAIL=admin@athleteshield.local
SEED_ADMIN_PASSWORD=replace-with-strong-admin-password
